# Next.js Static Export - cPanel Configuration

# Enable Rewrite Engine
RewriteEngine On

# Block RSC requests (React Server Components) - return 204 No Content
RewriteCond %{REQUEST_URI} __next\..*\.txt$ [OR]
RewriteCond %{REQUEST_URI} __PAGE__\.txt$
RewriteRule ^ - [R=204,L]

# Block problematic prefetch requests that don't have full paths
# Return 204 for relative URLs like "assignments/", "exams/", etc.
RewriteCond %{REQUEST_URI} ^/(assignments|exams|attendance|reports|submissions|subjects|timetable)/?$
RewriteRule ^ - [R=204,L]

# Allow HEAD requests without errors
RewriteCond %{REQUEST_METHOD} HEAD
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /$1/index.html [L,NC,END]

# Add trailing slash if directory exists
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ $1/ [L,R=301]

# Serve existing files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Handle Next.js routing - serve index.html for directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/.*\.(css|js|jpg|jpeg|png|gif|svg|ico|woff|woff2|ttf|eot|json|txt|xml)$
RewriteRule ^(.*)$ /$1/index.html [L,NC]

# If that fails, try root index.html (for client-side routing)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L,NC]

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>
